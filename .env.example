# Application
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
DASHBOARD_URL=http://localhost:8090

# Mobile app bypass token (used by Android WebView to skip login)
APP_TOKEN=change-me-to-a-secret-token

# Database (Login system)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=dashboard
DB_PASSWORD=dashboard
DB_DATABASE=login

# Odoo API
ODOO_URL=https://odoo.com/yourodoo
ODOO_DB=odoo_db
ODOO_LOGIN=odoologin@email.com
ODOO_PASSWORD=12345678

# Company IDs for Odoo API queries
ODOO_COMPANY_IDS=13,18,7,5,2,17,4,14,15,12,3,8,19,20,21,22

# Partner rotation order (for slideshow auto-redirect)
PARTNER_ROTATION=ARTAJASA,DANA,MANDIRI,MTI,NDP,OVO

# Slideshow timing (seconds before redirecting to next partner)
SLIDESHOW_REDIRECT_SECONDS=120

# Storage paths
STORAGE_LOG_PATH=storage/log
STORAGE_COOKIES_PATH=storage/cookies.txt
